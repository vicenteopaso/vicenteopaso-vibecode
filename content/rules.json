{
  "version": 1,

  "matching": {
    "min_match_score": 0.8,
    "require_recommended_flag": true,
    "prioritize_titles": [
      "Engineering Manager",
      "Web Engineering Manager",
      "Frontend Engineering Manager",
      "Tech Lead",
      "Team Lead",
      "Lead Engineer"
    ],
    "secondary_titles": [
      "Senior Frontend Engineer",
      "Staff Frontend Engineer",
      "Principal Frontend Engineer",
      "Staff Engineer",
      "Principal Engineer",
      "Design System Engineer",
      "Developer Experience Engineer"
    ],
    "title_priority_boosts": {
      "engineering manager": 0.08,
      "frontend engineering manager": 0.1,
      "web engineering manager": 0.1,
      "tech lead": 0.07,
      "team lead": 0.06,
      "lead engineer": 0.05,
      "staff engineer": 0.03,
      "principal engineer": 0.03,
      "senior frontend engineer": 0.02
    }
  },

  "hard_filters": {
    "exclude_open_opportunities": true,
    "exclude_titles_containing": [
      "designer",
      "product designer",
      "ux designer",
      "ui designer",
      "graphic designer",
      "intern",
      "junior"
    ],
    "exclude_keywords_in_description": [
      "open application",
      "general interest",
      "talent pool"
    ],
    "allowed_work_models": ["remote", "hybrid"],
    "exclude_work_models": ["onsite"]
  },

  "queue": {
    "max_new_linear_issues_per_day": 30,
    "carry_over_overflow": true,
    "max_job_age_days": 45,
    "recheck_queued_jobs_each_run": true,
    "drop_jobs_if_closed": true
  },

  "deduplication": {
    "dedupe_by": ["canonical_url", "company", "title"],
    "ignore_query_params": true,
    "cross_source_duplicate_window_days": 30
  },

  "scoring": {
    "batch_size_for_llm_matching": 20,
    "max_description_chars_per_job": 3000,
    "prefer_remote": true,
    "prefer_europe_friendly": true,
    "penalize_unclear_location": false
  },

  "linear": {
    "create_issue_only_if_above_threshold": true,
    "default_team_key": "JOB",
    "default_labels": ["job-search"],
    "include_match_reasons": true,
    "include_dealbreakers": true
  },

  "operations": {
    "runs_per_day": 2,
    "timezone": "Europe/Madrid",
    "log_level": "info"
  }
}
