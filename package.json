{
  "name": "vicenteopaso-vibecode",
  "version": "1.3.3",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "SENTRY_DSN= SENTRY_AUTH_TOKEN= NEXT_TELEMETRY_DISABLED=1 vitest --run",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test test/e2e",
    "test:e2e:ui": "playwright test test/e2e --ui",
    "test:visual": "playwright test test/visual",
    "test:visual:update": "playwright test test/visual --update-snapshots",
    "coverage": "mkdir -p coverage/unit/.tmp && SENTRY_DSN= SENTRY_AUTH_TOKEN= NEXT_TELEMETRY_DISABLED=1 vitest run --coverage",
    "content": "node scripts/contentlayer-build.mjs",
    "clean": "node scripts/clean-local.mjs",
    "reset": "pnpm clean && pnpm install && pnpm build",
    "verify": "pnpm install && pnpm lint && pnpm format && pnpm typecheck && pnpm audit:secrets && pnpm validate:links && pnpm test && pnpm test:e2e && pnpm build && pnpm coverage && pnpm sitemap",
    "verify:fix": "pnpm install && pnpm lint:fix && pnpm format:fix && pnpm typecheck && pnpm audit:secrets && pnpm validate:links && pnpm test && pnpm test:e2e && pnpm build && pnpm coverage && pnpm sitemap",
    "validate:links": "node scripts/validate-links.mjs",
    "audit:a11y": "node scripts/audit-a11y.mjs",
    "audit:lighthouse": "node scripts/audit-lighthouse.mjs",
    "audit:security": "pnpm audit --audit-level=high",
    "audit:security:fix": "pnpm audit --fix --audit-level=high",
    "audit:secrets": "node scripts/scan-secrets.mjs",
    "sitemap": "next-sitemap --config next-sitemap.config.js",
    "translate": "node scripts/translate.mjs"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@sentry/nextjs": "^10.62.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.5.2",
    "clsx": "^2.1.1",
    "contentlayer": "^0.3.4",
    "gray-matter": "^4.0.3",
    "next": "^16.2.9",
    "next-contentlayer": "^0.3.4",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "sanitize-html": "^2.17.5",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@playwright/test": "^1.61.1",
    "@sentry/cli-darwin": "^3.6.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "deepl-node": "^1.27.0",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "import-in-the-middle": "^3.2.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.16",
    "prettier": "^3.9.1",
    "require-in-the-middle": "^8.0.1",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-radix": "^4.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.{md,mdx,json,css}": [
      "prettier --write"
    ]
  }
}
